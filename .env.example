# Copy this file to `.env` (not committed) and fill in real values.
#
#   cp .env.example .env
#   nano .env

# Admin panel login password.
# ⚠️ Use a 16+ char random string. Any placeholder shown in the repo or chat
# logs is treated as leaked — don't reuse it.
WANGUI_ADMIN_PASS=换成你自己的强密码

# AES-256 master key. Encrypts user school tokens and the SMTP password at rest.
# Generate with: openssl rand -hex 32
# ⚠️ Back this up to a password manager. Losing it = the database is unreadable.
# Never regenerate after the first deploy.
WANGUI_MASTER_KEY=用 openssl rand -hex 32 生成的 64 字符 hex
